          </div>
        </div>
      )}
      <div className="flex justify-end"><SaveBtn onClick={save} saved={saved} /></div>
    </div>
  );
}

/* ─────────────────────── PRICING TAB ─────────────────────── */
function PricingTab({ biz, setBiz }) {
  const [adding, setAdding] = useState(false);
  const [np, setNp] = useState({ name: "", price: "", cur: "₦", period: "/mo", hot: false, features: [""] });
  const [saved, setSaved] = useState(false);

  const addPlan = () => {
    if (!np.name || !np.price) return;
    setBiz((b) => ({ ...b, pricing: [...b.pricing, { id: uid(), ...np, features: np.features.filter(Boolean) }] }));
    setNp({ name: "", price: "", cur: "₦", period: "/mo", hot: false, features: [""] }); setAdding(false);
  };
  const del = (id) => setBiz((b) => ({ ...b, pricing: b.pricing.filter((p) => p.id !== id) }));
  const setFeat = (i, val) => setNp((n) => { const f = [...n.features]; f[i] = val; return { ...n, features: f }; });
  const save = () => { setSaved(true); setTimeout(() => setSaved(false), 2000); };

  return (
    <div className="space-y-4 max-w-2xl">
      <div className="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm">
        <div className="flex items-center justify-between mb-4">
          <h3 className="font-bold text-slate-800 flex items-center gap-2"><DollarSign size={18} className="text-blue-600" /> Pricing Plans ({biz.pricing.length})</h3>
          <button onClick={() => setAdding(true)} className="flex items-center gap-1.5 bg-blue-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-blue-500 transition-colors">
