                  <span className={`text-sm ${p.hot ? "text-blue-200" : "text-slate-400"}`}>{p.period}</span>
                </div>
                <div className="space-y-3 mb-8">
                  {p.features.map((f, i) => (
                    <div key={i} className="flex items-center gap-2.5">
                      <div className={`w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 ${p.hot ? "bg-white/20" : "bg-blue-50"}`}>
                        <Check size={11} className={p.hot ? "text-white" : "text-blue-600"} />
                      </div>
                      <span className={`text-sm ${p.hot ? "text-blue-100" : "text-slate-600"}`}>{f}</span>
                    </div>
                  ))}
                </div>
                <a href={waLink(biz.whatsapp)} target="_blank" rel="noreferrer"
                  className={`block text-center py-3 rounded-xl font-bold transition-all ${p.hot ? "bg-white text-blue-700 hover:bg-blue-50" : "bg-blue-600 text-white hover:bg-blue-500"}`}>
                  Get Started
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── TESTIMONIALS ── */}
      <section className="py-24 bg-slate-950">
        <div className="max-w-5xl mx-auto px-6">
          <div className="text-center mb-14">
            <span className="text-blue-400 font-bold text-sm uppercase tracking-widest">Social Proof</span>
            <h2 className="text-4xl font-black text-white mt-2">What Our Clients Say</h2>
          </div>
          <div className="grid md:grid-cols-3 gap-6">
            {biz.testimonials.map((t, i) => (
              <div key={t.id} className="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/8 transition-colors">
                <div className="flex gap-0.5 mb-4">
                  {[...Array(5)].map((_, j) => <span key={j} className="text-amber-400 text-sm">★</span>)}
                </div>
                <p className="text-slate-300 text-sm leading-relaxed mb-5">"{t.text}"</p>
                <div className="flex items-center gap-3">
                  <div className={`w-10 h-10 rounded-xl bg-gradient-to-br ${avatarGrads[i % avatarGrads.length]} flex items-center justify-center text-white font-bold text-xs`}>{t.av}</div>
                  <div>
                    <p className="text-white font-bold text-sm">{t.name}</p>
                    <p className="text-slate-500 text-xs">{t.role}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── FAQ ── */}
      <section className="py-24 bg-white">
        <div className="max-w-3xl mx-auto px-6">
          <div className="text-center mb-14">
            <span className="text-blue-600 font-bold text-sm uppercase tracking-widest">FAQ</span>
            <h2 className="text-4xl font-black text-slate-900 mt-2">Frequently Asked Questions</h2>
          </div>
          <div className="space-y-3">
            {biz.faqs.map((f) => (
              <div key={f.id} className="border border-slate-200 rounded-2xl overflow-hidden">
                <button onClick={() => setOpenFaq(openFaq === f.id ? null : f.id)}
                  className="w-full flex items-center justify-between px-6 py-5 text-left hover:bg-slate-50 transition-colors">
                  <span className="font-bold text-slate-800 text-sm pr-4">{f.q}</span>
                  <div className={`w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 transition-all ${openFaq === f.id ? "bg-blue-600 text-white rotate-180" : "bg-slate-100 text-slate-600"}`}>
                    <ChevronDown size={15} />
                  </div>
                </button>
                {openFaq === f.id && (
                  <div className="px-6 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-100 pt-4">{f.a}</div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ── CONTACT ── */}
      <section id="contact" className="py-24 bg-slate-50">
        <div className="max-w-5xl mx-auto px-6">
          <div className="grid md:grid-cols-2 gap-12 items-start">
            <div>
              <span className="text-blue-600 font-bold text-sm uppercase tracking-widest">Get In Touch</span>
              <h2 className="text-4xl font-black text-slate-900 mt-2 mb-4">Ready to Grow Your Business?</h2>
              <p className="text-slate-600 mb-8">Reach out via WhatsApp for the fastest response, or fill the form and we'll get back to you shortly.</p>
              <div className="space-y-4 mb-8">
                {[
                  { icon: MessageCircle, text: biz.whatsapp, color: "green", href: waLink(biz.whatsapp) },
                  { icon: Mail, text: biz.email, color: "blue", href: `mailto:${biz.email}` },
                  { icon: Phone, text: biz.phone, color: "purple", href: `tel:${biz.phone}` },
                  { icon: MapPin, text: biz.address, color: "red", href: null },
                ].map(({ icon: Icon, text, color, href }) => {
                  const colors2 = { green: "bg-green-50 text-green-600", blue: "bg-blue-50 text-blue-600", purple: "bg-purple-50 text-purple-600", red: "bg-red-50 text-red-600" };
                  const inner = (
                    <div key={text} className="flex items-center gap-3">
                      <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${colors2[color]}`}><Icon size={18} /></div>
                      <span className="text-slate-700 text-sm font-medium">{text}</span>
                    </div>
                  );
                  return href ? <a href={href} key={text} target="_blank" rel="noreferrer" className="hover:opacity-80 transition-opacity">{inner}</a> : <div key={text}>{inner}</div>;
                })}
              </div>
              <a href={waLink(biz.whatsapp)} target="_blank" rel="noreferrer"
                className="inline-flex items-center gap-2.5 bg-green-500 hover:bg-green-400 text-white font-bold px-7 py-4 rounded-2xl transition-all shadow-lg shadow-green-500/20 text-lg">
                <MessageCircle size={20} /> Chat on WhatsApp Now
              </a>
            </div>
            <div className="bg-white rounded-3xl p-7 shadow-sm border border-slate-100">
              {formSent ? (
                <div className="text-center py-8">
                  <div className="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4"><CheckCircle size={28} className="text-green-600" /></div>
                  <h3 className="font-black text-slate-800 text-xl mb-2">Message Sent! 🎉</h3>
                  <p className="text-slate-500 text-sm">We'll get back to you within 24 hours. Or chat on WhatsApp for instant response!</p>
                  <a href={waLink(biz.whatsapp)} target="_blank" rel="noreferrer"
                    className="inline-flex items-center gap-2 mt-5 bg-green-500 text-white font-bold px-5 py-3 rounded-xl text-sm hover:bg-green-400 transition-colors">
                    <MessageCircle size={16} /> WhatsApp Us
                  </a>
                </div>
              ) : (
                <>
                  <h3 className="font-black text-slate-800 text-xl mb-6">Send a Message</h3>
                  <div className="space-y-4">
                    <div>
                      <label className="block text-sm font-semibold text-slate-700 mb-1.5">Your Name</label>
                      <input value={formName} onChange={(e) => setFormName(e.target.value)} placeholder="Full Name"
                        className="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-blue-500 bg-white" />
                    </div>
                    <div>
                      <label className="block text-sm font-semibold text-slate-700 mb-1.5">Email Address</label>
                      <input value={formEmail} onChange={(e) => setFormEmail(e.target.value)} placeholder="your@email.com"
                        className="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-blue-500 bg-white" />
                    </div>
                    <div>
                      <label className="block text-sm font-semibold text-slate-700 mb-1.5">Message</label>
                      <textarea value={formMsg} onChange={(e) => setFormMsg(e.target.value)} placeholder="How can we help you?" rows={4}
                        className="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:border-blue-500 resize-none bg-white" />
                    </div>
                    <button onClick={submitForm}
                      className="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-xl transition-colors flex items-center justify-center gap-2">
                      <Send size={16} /> Send Message
                    </button>
                  </div>
                </>
              )}
            </div>
          </div>
        </div>
      </section>

      {/* ── FOOTER ── */}
      <footer className="bg-slate-950 py-16 px-6">
        <div className="max-w-5xl mx-auto">
          <div className="grid md:grid-cols-3 gap-10 mb-12">
            <div>
              <div className="flex items-center gap-3 mb-4">
                <div className="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-700 rounded-xl flex items-center justify-center text-white font-black text-sm">{biz.logoText}</div>
                <span className="text-white font-black text-xl">{biz.name}</span>
              </div>
              <p className="text-slate-500 text-sm leading-relaxed">{biz.tagline}</p>
              <div className="flex gap-3 mt-5">
                {biz.tiktok && <a href="#" className="w-9 h-9 bg-white/10 rounded-xl flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/20 transition-all text-xs font-bold">TK</a>}
                {biz.instagram && <a href="#" className="w-9 h-9 bg-white/10 rounded-xl flex items-center justify-center text-slate-400 hover:text-pink-400 hover:bg-pink-500/20 transition-all"><Instagram size={16} /></a>}
                {biz.twitter && <a href="#" className="w-9 h-9 bg-white/10 rounded-xl flex items-center justify-center text-slate-400 hover:text-sky-400 hover:bg-sky-500/20 transition-all"><Twitter size={16} /></a>}
                {biz.facebook && <a href="#" className="w-9 h-9 bg-white/10 rounded-xl flex items-center justify-center text-slate-400 hover:text-blue-400 hover:bg-blue-500/20 transition-all"><Facebook size={16} /></a>}
              </div>
            </div>
            <div>
              <h4 className="text-white font-bold mb-4 text-sm">Quick Links</h4>
              <div className="space-y-2">
                {["About", "Services", "Pricing", "Testimonials", "FAQ", "Contact"].map((l) => (
                  <a key={l} href={`#${l.toLowerCase()}`} className="block text-slate-500 hover:text-white text-sm transition-colors">{l}</a>
                ))}
              </div>
            </div>
            <div>
              <h4 className="text-white font-bold mb-4 text-sm">Contact Us</h4>
              <div className="space-y-3">
                <a href={waLink(biz.whatsapp)} target="_blank" rel="noreferrer" className="flex items-center gap-2.5 text-slate-500 hover:text-green-400 text-sm transition-colors"><MessageCircle size={15} />{biz.whatsapp}</a>
                <a href={`mailto:${biz.email}`} className="flex items-center gap-2.5 text-slate-500 hover:text-white text-sm transition-colors"><Mail size={15} />{biz.email}</a>
                <div className="flex items-start gap-2.5 text-slate-500 text-sm"><MapPin size={15} className="mt-0.5 flex-shrink-0" />{biz.address}</div>
              </div>
            </div>
          </div>
          <div className="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3">
            <p className="text-slate-600 text-xs">© {new Date().getFullYear()} {biz.name}. All rights reserved.</p>
            <p className="text-slate-600 text-xs flex items-center gap-1">Built with <Zap size={11} className="text-blue-500" /> BusinessHub</p>
          </div>
        </div>
      </footer>

      {/* Floating WhatsApp */}
      <a href={waLink(biz.whatsapp)} target="_blank" rel="noreferrer"
        className="fixed bottom-6 right-6 w-14 h-14 bg-green-500 hover:bg-green-400 rounded-full flex items-center justify-center shadow-2xl shadow-green-500/40 transition-all hover:scale-110 z-40">
        <MessageCircle size={24} className="text-white" />
      </a>
    </div>
  );
}

/* ─────────────────────── ROOT APP ─────────────────────── */
export default function App() {
  const [screen, setScreen] = useState("auth");
  const [activeTab, setActiveTab] = useState("overview");
  const [biz, setBiz] = useState(DEFAULT);
  const [showPublish, setShowPublish] = useState(false);
  const [mobileOpen, setMobileOpen] = useState(false);

  const TABS = { overview: OverviewTab, business: BusinessTab, services: ServicesTab, pricing: PricingTab, testimonials: TestimonialsTab, faq: FAQTab, social: SocialTab };
  const TabComponent = TABS[activeTab] || OverviewTab;

  if (screen === "auth") return <AuthPage onLogin={() => setScreen("dashboard")} />;
  if (screen === "preview") return <LandingPage biz={biz} onBack={() => setScreen("dashboard")} />;

  return (
    <div className="flex h-screen bg-slate-50 overflow-hidden">
      <Sidebar active={activeTab} setActive={setActiveTab} onPreview={() => setScreen("preview")} onLogout={() => setScreen("auth")} biz={biz} onPublish={() => setShowPublish(true)} mobileOpen={mobileOpen} setMobileOpen={setMobileOpen} />
      <main className="flex-1 overflow-y-auto lg:pt-0 pt-14">
        <div className="max-w-3xl mx-auto px-5 py-8">
          <div className="mb-7">
            <h1 className="text-2xl font-black text-slate-900 capitalize">{activeTab === "overview" ? "Dashboard Overview" : activeTab === "business" ? "Business Info" : activeTab === "social" ? "Social & Contact" : `${activeTab.charAt(0).toUpperCase()}${activeTab.slice(1)}`}</h1>
            <p className="text-slate-500 text-sm mt-1">
              {activeTab === "overview" && "Your page performance at a glance."}
              {activeTab === "business" && "Update your business name, tagline, and description."}
              {activeTab === "services" && "Manage the services shown on your landing page."}
              {activeTab === "pricing" && "Set up your pricing plans."}
              {activeTab === "testimonials" && "Showcase customer reviews and success stories."}
              {activeTab === "faq" && "Answer common questions your customers ask."}
              {activeTab === "social" && "Add your contact details and social media links."}
            </p>
          </div>
          <TabComponent biz={biz} setBiz={setBiz} />
        </div>
      </main>
      {showPublish && (
        <PublishModal biz={biz} onClose={() => setShowPublish(false)} onPublish={() => setBiz((b) => ({ ...b, published: true }))} />
      )}
    </div>
  );
}
