      </div>
      <div className="relative w-full max-w-md">
        <div className="text-center mb-8">
          <div className="inline-flex items-center gap-2.5 mb-3">
            <div className="w-11 h-11 bg-gradient-to-br from-blue-500 to-blue-700 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30">
              <Zap size={20} className="text-white" />
            </div>
            <span className="text-3xl font-black text-white tracking-tight">BusinessHub</span>
          </div>
          <p className="text-slate-400 text-sm">Build professional landing pages — no code needed</p>
        </div>
        <div className="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">
          <h2 className="text-white font-bold text-xl mb-6 text-center">
            {mode === "login" ? "Welcome back 👋" : "Create your account ✨"}
